# Copy this file to .env and fill in the values. .env is not committed to git.
# The LLM request is OpenAI-compatible: POST {LLM_BASE_URL}/chat/completions

# API key (required in real mode; do NOT commit a real key)
LLM_API_KEY=

# OpenAI-compatible API base, e.g.:
#   https://api.openai.com/v1
#   https://openrouter.ai/api/v1
#   http://localhost:1234/v1   (local server)
LLM_BASE_URL=https://api.openai.com/v1

# Model name (optional; defaults to gpt-4o-mini)
LLM_MODEL=gpt-4o-mini
