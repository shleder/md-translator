# Скопируй этот файл в .env и заполни значения. .env в git не коммитится.
# Запрос к LLM — OpenAI-совместимый: POST {LLM_BASE_URL}/chat/completions

# Ключ API (обязателен в реальном режиме; НЕ коммить настоящий ключ)
LLM_API_KEY=

# База OpenAI-совместимого API, напр.:
#   https://api.openai.com/v1
#   https://openrouter.ai/api/v1
#   http://localhost:1234/v1   (локальный сервер)
LLM_BASE_URL=https://api.openai.com/v1

# Имя модели (опционально; по умолчанию gpt-4o-mini)
LLM_MODEL=gpt-4o-mini
